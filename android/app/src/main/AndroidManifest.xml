<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- PetPal permissions -->
    <!-- Notifications: Phase 4 reminders fire local notifications (Android 13+ requires runtime grant). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <!-- Exact alarms: deterministic-mode reminders need precise wall-clock firing. -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"/>
    <!-- USE_EXACT_ALARM is the post-Android 13 alternative; declared so the AlarmManager API works without user grant on supported devices. -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM"/>
    <!-- Re-arm pending reminders after device reboot. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <!-- Required by android_alarm_manager_plus to wake the device for
         exact-time alarms. The plugin acquires a partial wakelock in
         AlarmBroadcastReceiver before invoking the Dart callback. -->
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    <!-- Internet: Anthropic API + future cloud sync. -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:label="PetPal"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- Phase 7 task H.1.a — Supabase magic-link return deep
                 link (DECISIONS rows 70 + 82). The custom URL scheme
                 `petpal://login-callback` is registered as Supabase's
                 `emailRedirectTo` for `signInWithOtp` calls. When the
                 user taps the magic link from email, Android resolves
                 the URI to MainActivity, supabase_flutter's bundled
                 app_links listener catches it, and the auth client
                 fires a `signedIn` event that flows through
                 AuthSessionNotifier without per-activity glue. This
                 scheme MUST also be registered in the Supabase Auth
                 → Settings → "Additional redirect URLs" dashboard;
                 documented in docs/SETUP.md. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data
                    android:scheme="petpal"
                    android:host="login-callback"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- android_alarm_manager_plus 4.0.x platform glue. The plugin
             classes live in `dev.fluttercommunity.plus.androidalarmmanager.*`;
             they're contributed by the plugin's AAR but the consumer app
             must declare them in the merged manifest so AlarmManager and
             PackageManager can resolve them. Without these declarations,
             `oneShotAt(rescheduleOnReboot: true)` crashes with
             "Component class … RebootBroadcastReceiver does not exist
             in dev.blokz.petpal" — the Phase 4 hotfix DECISIONS row 33. -->
        <service
            android:name="dev.fluttercommunity.plus.androidalarmmanager.AlarmService"
            android:exported="false"
            android:permission="android.permission.BIND_JOB_SERVICE"/>
        <receiver
            android:name="dev.fluttercommunity.plus.androidalarmmanager.AlarmBroadcastReceiver"
            android:exported="false"/>
        <!-- The reboot receiver ships disabled; the plugin enables it
             at runtime via PackageManager.setComponentEnabledSetting
             when a reminder schedules with rescheduleOnReboot=true. -->
        <receiver
            android:name="dev.fluttercommunity.plus.androidalarmmanager.RebootBroadcastReceiver"
            android:enabled="false"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
            </intent-filter>
        </receiver>
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
